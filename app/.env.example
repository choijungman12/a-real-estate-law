# ============================================================
# 한국 부동산 플랫폼 환경변수
# ============================================================
# 각 API 키 발급 방법은 docs/api-keys-setup.md 참조
# .env.local 로 복사 후 실제 값 입력 (절대 커밋 금지)
# ============================================================

# --- AI ---
ANTHROPIC_API_KEY=sk-ant-...

# --- 공공데이터포털 (data.go.kr) 통합 키 ---
# 회원가입 후 마이페이지에서 발급. 일반·디코딩 키 둘 다 받기.
DATA_GO_KR_KEY_ENCODED=
DATA_GO_KR_KEY_DECODED=

# --- 국가법령정보센터 (open.law.go.kr) ---
# 별도 가입, OC 코드(이메일 ID 앞부분)
LAW_GO_KR_OC=

# --- V월드 (vworld.kr) ---
# 회원가입 → 오픈API → 인증키 발급, 도메인 등록 필수
VWORLD_API_KEY=
# 클라이언트 노출용 동일값 (지도 오버레이에서 사용)
NEXT_PUBLIC_VWORLD_API_KEY=

# --- 법원 등기정보광장 (data.iros.go.kr) — 선택, 사건번호 모드 정확도 향상 ---
# https://data.iros.go.kr/rp/oa/openOapiAppl.do
# 본인 또는 정당한 이해관계자만 사용 가능
IROS_API_KEY=

# --- 한국부동산원 R-ONE (reb.or.kr) ---
REB_API_KEY=

# --- 카카오맵 (developers.kakao.com) ---
NEXT_PUBLIC_KAKAO_JS_KEY=
KAKAO_REST_KEY=

# --- 네이버 검색 API (developers.naver.com) ---
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- 텔레그램 봇 (BotFather) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- DB (Supabase 무료 티어 권장) ---
# https://supabase.com/dashboard 에서 새 프로젝트 생성 → Settings → Database
# "Connection string (URI)" 복사 (transaction pooler 6543 권장)
# 마이그레이션: pnpm exec drizzle-kit push
DATABASE_URL=

# Vercel Cron 보안용 (선택, Vercel cron이 헤더로 자동 인증)
CRON_SECRET=
